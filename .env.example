# Copia a .env y ajusta (no subas .env al repositorio).

# MySQL — preferido (server/utils/db.ts + nuxt.config runtimeConfig)
# En Vercel: usa el hostname/IP pública de tu proveedor MySQL. 127.0.0.1 / localhost
# solo sirve si la base está en la misma máquina que el proceso (no aplica en serverless).
DB_HOST=localhost
DB_PORT=3306
DB_USER=sa
DB_PASSWORD=
DB_NAME=tradeadmin_sergio_erp_comercial
# Tras conectar, el plugin del servidor crea tablas (InnoDB) si faltan.
# Seed demo (mock → MySQL): solo cuando no hay proyectos Y SEED_ERP=true (omitir en producción).
# Alias aceptado: NUXT_SEED_ERP=true

# Respaldo (misma app): variables antiguas NUXT_MYSQL_* si aún las tienes en hosting.
# NUXT_MYSQL_HOST=localhost
# NUXT_MYSQL_PORT=3306
# NUXT_MYSQL_USER=sa
# NUXT_MYSQL_PASSWORD=
# NUXT_MYSQL_DATABASE=tradeadmin_sergio_erp_comercial

# URLs públicas de imágenes subidas (/api/articulos/upload)
NUXT_PUBLIC_UPLOADS_PUBLIC_BASE=http://erp.tradestandart.com.mx/uploads/articulos

# Autenticación (si no usas login, déjalo en false)
NUXT_PUBLIC_REQUIRE_AUTH=false
